{
  "name": "ibid-service",
  "version": "0.4.0",
  "private": true,
  "description": "HTTP wrapper around @bwthomas/ibid for non-TypeScript consumers",
  "license": "MIT",
  "author": "Blake Thomas <bwthomas@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bwthomas/ibid-service.git"
  },
  "homepage": "https://github.com/bwthomas/ibid-service#readme",
  "bugs": {
    "url": "https://github.com/bwthomas/ibid-service/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess 'node dist/server.js'",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@bwthomas/ibid": "file:../ibid",
    "fastify": "^5.0.0",
    "linkedom": "^0.18.12",
    "lru-cache": "^11.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^3.0.0"
  }
}
